# =========================================================
# Frota 360 — Variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores.
# =========================================================

# --- Supabase ---------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- URL pública (para links de reset de senha) -----------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Assistente IA (Gemini 2.5 Flash) ---------------------
# Obtenha em https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua_chave_aqui

# --- Email (Resend) ----------------------------------------
# Criar conta em https://resend.com — plano gratuito: 3.000 e-mails/mês
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=nao-responda@frota360.com.br

# --- Cron (string aleatória forte) ------------------------
# Usada para autenticar chamadas de cron jobs internos
CRON_SECRET=mude_para_uma_string_forte_e_aleatoria_aqui

# --- Mercado Pago (Sprint futura: billing) ----------------
MERCADOPAGO_ACCESS_TOKEN=
